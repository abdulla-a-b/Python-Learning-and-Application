<style>
  @keyframes fadeSlideDown {
    from { opacity: 0; transform: translateY(-18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes arrowRight {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0% 0 0); }
  }
  @keyframes arrowLeft {
    from { clip-path: inset(0 0 0 100%); }
    to   { clip-path: inset(0 0 0 0%); }
  }
  @keyframes pulseBadge {
    0%,100% { box-shadow: 0 0 0 0px rgba(55,138,221,0.3); }
    50%      { box-shadow: 0 0 0 5px rgba(55,138,221,0); }
  }

  .list-wrap { padding: 1.5rem 1rem 1rem; font-family: sans-serif; }
  h2 { text-align: center; font-size: 17px; font-weight: 500; margin: 0 0 4px; }
  .subtitle { text-align: center; font-size: 13px; color: gray; margin: 0 0 20px; }

  .container-box {
    border: 1.5px solid #aaa;
    border-radius: 16px;
    padding: 14px 14px 10px;
    background: #f5f5f5;
    margin: 0 0 6px;
  }
  .items-row { display: flex; gap: 8px; justify-content: center; }

  .item {
    flex: 1;
    border: 1.5px solid #378ADD;
    border-radius: 10px;
    background: #E6F1FB;
    padding: 10px 6px 6px;
    text-align: center;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    opacity: 0;
    animation: fadeSlideDown 0.4s ease forwards;
  }
  .item:hover { transform: translateY(-3px); box-shadow: 0 4px 12px rgba(55,138,221,0.2); }
  .item.active { animation: pulseBadge 1s ease infinite; border-width: 2px; }

  .item-value { font-size: 15px; font-weight: 500; color: #0C447C; }
  .item-type  { font-size: 11px; color: #185FA5; margin-top: 2px; }

  .index-row { display: flex; gap: 8px; justify-content: center; margin-top: 10px; }
  .idx-cell  { flex: 1; text-align: center; }
  .pos-idx   { font-size: 12px; color: gray; opacity: 0; animation: fadeSlideUp 0.4s ease forwards; }
  .neg-idx   { font-size: 11px; color: #bbb; margin-top: 2px; opacity: 0; animation: fadeSlideUp 0.45s ease 0.2s forwards; }

  .arrows-row { display: flex; flex-direction: column; gap: 6px; margin-top: 14px; }
  .arrow-line { display: flex; align-items: center; gap: 8px; font-size: 12px; color: gray; }
  .arrow-svg  { flex: 1; height: 18px; opacity: 0; }
  .arrow-svg.pos { animation: arrowRight 0.7s ease 1.0s forwards; }
  .arrow-svg.neg { animation: arrowLeft  0.7s ease 1.2s forwards; }

  .info-box {
    margin-top: 18px;
    padding: 12px 14px;
    background: white;
    border: 0.5px solid #ddd;
    border-radius: 12px;
    font-size: 13px;
    color: #555;
    min-height: 44px;
  }
  code { font-family: monospace; font-size: 12px; background: #f0f0f0; border-radius: 4px; padding: 1px 5px; }
</style>

<div class="list-wrap">
  <h2>How a Python list works</h2>
  <p class="subtitle">An ordered collection — each item has a position (index) starting from 0</p>

  <div class="container-box">
    <div class="items-row" id="items-row"></div>
  </div>

  <div class="index-row" id="index-row"></div>

  <div class="arrows-row">
    <div class="arrow-line">
      <svg class="arrow-svg pos" viewBox="0 0 200 18" preserveAspectRatio="none">
        <line x1="2" y1="9" x2="194" y2="9" stroke="gray" stroke-width="1"/>
        <polyline points="186,4 194,9 186,14" fill="none" stroke="gray" stroke-width="1.2"/>
      </svg>
      <span style="white-space:nowrap;opacity:0;animation:fadeSlideUp 0.4s ease 1.0s forwards">positive indexing →</span>
    </div>
    <div class="arrow-line">
      <span style="white-space:nowrap;opacity:0;animation:fadeSlideUp 0.4s ease 1.2s forwards">← negative indexing</span>
      <svg class="arrow-svg neg" viewBox="0 0 200 18" preserveAspectRatio="none">
        <line x1="198" y1="9" x2="6" y2="9" stroke="gray" stroke-width="1"/>
        <polyline points="14,4 6,9 14,14" fill="none" stroke="gray" stroke-width="1.2"/>
      </svg>
    </div>
  </div>

  <div class="info-box" id="info-box">Click any item to explore it.</div>
</div>

<script>
const items = [
  { value: '"Alice"', type: 'str',   detail: 'A string — text in quotes. Access: my_list[0] or my_list[-6].' },
  { value: '25',      type: 'int',   detail: 'An integer — whole number. Access: my_list[1] or my_list[-5].' },
  { value: '3.14',    type: 'float', detail: 'A float — decimal number. Access: my_list[2] or my_list[-4].' },
  { value: 'True',    type: 'bool',  detail: 'A boolean — True or False. Access: my_list[3] or my_list[-3].' },
  { value: '[1, 2]',  type: 'list',  detail: 'A nested list — lists can hold other lists! Access: my_list[4] or my_list[-2].' },
  { value: '"Bob"',   type: 'str',   detail: 'Another string. Lists freely mix any types. Access: my_list[5] or my_list[-1].' },
];

const n = items.length;

items.forEach((it, i) => {
  const delay = `${0.05 + i * 0.08}s`;

  // Item box
  const div = document.createElement('div');
  div.className = 'item';
  div.style.animationDelay = delay;
  div.innerHTML = `<div class="item-value">${it.value}</div><div class="item-type">${it.type}</div>`;
  div.addEventListener('click', () => {
    document.querySelectorAll('.item').forEach(el => el.classList.remove('active'));
    div.classList.add('active');
    document.getElementById('info-box').innerHTML =
      `<strong>Index ${i} (or ${i - n})</strong> · type: <code>${it.type}</code><br>${it.detail}`;
  });
  document.getElementById('items-row').appendChild(div);

  // Index labels
  const cell = document.createElement('div');
  cell.className = 'idx-cell';
  cell.innerHTML = `
    <div class="pos-idx" style="animation-delay:${delay}">index ${i}</div>
    <div class="neg-idx" style="animation-delay:${delay}">${i - n}</div>`;
  document.getElementById('index-row').appendChild(cell);
});
</script>
